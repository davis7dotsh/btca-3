{
  "name": "@btca/convex",
  "version": "0.0.0",
  "description": "Reusable Convex component package for btca apps.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api.ts",
    "./data-model": "./src/data-model.ts",
    "./auth.config": "./convex/auth.config.ts",
    "./schema": "./convex/schema.ts",
    "./convex.config.js": "./convex/convex.config.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/src/index.mjs",
      "./api": "./dist/src/api.mjs",
      "./data-model": "./dist/src/data-model.mjs",
      "./convex.config.js": "./dist/convex/convex.config.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "convex-helpers": "^0.1.114"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "convex": "^1.34.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "convex": ">=1.25.0"
  }
}
